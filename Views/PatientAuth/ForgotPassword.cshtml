@model object
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card" style="max-width:440px;">
        <div class="auth-logo">Medical<span>Practice</span></div>
        <p class="auth-sub">Reset your password</p>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="mp-alert mp-alert-danger"
                 style="@(ViewData.ModelState.IsValid ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span asp-validation-summary="All"></span>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--mp-muted);"></i>
                    <input type="email" name="email" class="form-control" style="padding-left:2.4rem;" placeholder="Enter your registered email" required />
                </div>
            </div>

            <button type="submit" class="btn-mp-primary w-100" style="padding:.7rem;">
                <i class="bi bi-send me-2"></i>Send Reset PIN
            </button>
        </form>

        <div class="auth-divider"></div>
        <p class="text-center" style="font-size:.875rem;">
            <a asp-action="Login" style="color:var(--mp-accent); font-weight:600; text-decoration:none;">Back to Login</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}