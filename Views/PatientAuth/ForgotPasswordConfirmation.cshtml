@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card text-center" style="max-width:480px;">
        <i class="bi bi-check-circle-fill" style="font-size:3rem; color:var(--mp-success);"></i>
        <h4 class="mt-3">Check Your Email</h4>
        <p class="text-muted">If an account with that email exists, a password reset PIN has been sent.</p>
        <p class="text-muted">It expires in 15 minutes.</p>
        <a asp-action="Login" class="btn-mp-primary mt-2">Return to Login</a>
    </div>
</div>