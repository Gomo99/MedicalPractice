@model MedicalPractice.ViewModel.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card" style="max-width:440px;">
        <div class="auth-logo">Medical<span>Practice</span></div>
        <p class="auth-sub">Set a new password</p>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="All" class="mp-alert mp-alert-danger"
                 style="@(ViewData.ModelState.IsValid ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span asp-validation-summary="All"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Pin" class="form-label">Reset PIN</label>
                <input asp-for="Pin" class="form-control" placeholder="6-digit PIN" />
                <span asp-validation-for="Pin" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" placeholder="Min. 8 characters" type="password" />
                <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter password" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <button type="submit" class="btn-mp-primary w-100" style="padding:.7rem;">
                <i class="bi bi-shield-check me-2"></i>Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}