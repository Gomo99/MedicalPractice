@model MedicalPractice.ViewModel.CreateEmployeeViewModel
@{
    ViewData["Title"] = "Add Employee";
}

<div class="page-header">
    <h1><i class="bi bi-person-plus me-2" style="color:var(--mp-accent);"></i>Add New Employee</h1>
    <p>Create a new doctor or assistant account. A temporary password will be emailed to them.</p>
</div>

<div style="max-width:580px;">
    <div class="mp-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mp-alert mp-alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span asp-validation-summary="ModelOnly"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="e.g. Dr. Jane Smith" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label">Username</label>
                    <div style="position:relative;">
                        <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--mp-muted);font-size:.9rem;"></span>
                        <input asp-for="UserName" class="form-control" style="padding-left:2rem;" placeholder="janesmith" autocomplete="off" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="jane@practice.com" autocomplete="off" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Role" class="form-label">Role</label>
                    <select asp-for="Role" class="form-select">
                        <option value="">— Select a role —</option>
                        @foreach (var role in (IEnumerable<MedicalPractice.Status.UserRole>)ViewBag.Roles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="text-danger" style="font-size:.8rem;"></span>
                </div>
            </div>

            <div class="mp-alert mp-alert-info">
                <i class="bi bi-envelope-check"></i>
                A randomly generated password will be emailed to the employee. They will be prompted to change it on first login.
            </div>

            <div class="d-flex gap-3 mt-3">
                <button type="submit" class="btn-mp-primary flex-grow-1">
                    <i class="bi bi-person-check me-1"></i> Create Account
                </button>
                <a asp-action="DashBoard" class="btn-mp-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
