@model MedicalPractice.ViewModel.EditEmployeeViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="page-header">
    <h1><i class="bi bi-pencil-square me-2" style="color:var(--mp-accent);"></i>Edit Employee</h1>
    <p>Update employee account details</p>
</div>

<div style="max-width:580px;">
    <div class="mp-card">
        <form asp-action="Edit" asp-route-id="@Model.EmployeeID" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EmployeeID" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mp-alert mp-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="row g-3 mb-3">
                <div class="col-12">
                    <label asp-for="FullName" class="form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="Full name" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label">Username</label>
                    <div style="position:relative;">
                        <span style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--mp-muted);font-size:.9rem;"></span>
                        <input asp-for="UserName" class="form-control" style="padding-left:2rem;" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Role" class="form-label">Role</label>
                    <select asp-for="Role" class="form-select">
                        @foreach (var role in (IEnumerable<MedicalPractice.Status.UserRole>)ViewBag.Roles)
                        {
                            <option value="@role" selected="@(Model.Role.ToString() == role.ToString() ? "selected" : null)">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="text-danger" style="font-size:.8rem;"></span>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-mp-primary flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-action="DashBoard" class="btn-mp-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}