@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery AntiforgeryService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        /* Expose the CSRF token as a meta tag so our fetch() calls can send it
           as the RequestVerificationToken header without a full form post. */
        var csrfToken = AntiforgeryService.GetAndStoreTokens(Context).RequestToken;
    }
    <meta name="request-verification-token" content="@csrfToken" />
    <title>@ViewData["Title"] – MedicalPractice</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />

    <style>
        :root {
            --mp-primary:   #1a5f7a;
            --mp-secondary: #57c5b6;
            --mp-accent:    #159895;
            --mp-light:     #f4f9fb;
            --mp-dark:      #0d3d4d;
            --mp-text:      #1e2a2e;
            --mp-muted:     #6b8a93;
            --mp-border:    #d0e6ed;
            --mp-danger:    #c0392b;
            --mp-success:   #1a7a4a;
            --sidebar-w:    260px;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--mp-light);
            color: var(--mp-text);
            min-height: 100vh;
        }

        /* ── TOP NAV ─────────────────────────────── */
        .topbar {
            background: var(--mp-dark);
            height: 62px;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1050;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
        }
        .topbar-brand {
            font-family: 'DM Serif Display', serif;
            font-size: 1.25rem;
            color: #fff;
            text-decoration: none;
            letter-spacing: .4px;
            display: flex;
            align-items: center;
            gap: .6rem;
        }
        .topbar-brand .brand-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
            background: var(--mp-secondary);
            display: inline-block;
        }
        .topbar-brand:hover { color: var(--mp-secondary); }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: .75rem;
        }
        .topbar-user {
            color: #cde8ef;
            font-size: .875rem;
            font-weight: 500;
        }
        .topbar-logout {
            background: transparent;
            border: 1px solid rgba(255,255,255,.25);
            color: #fff;
            border-radius: 6px;
            padding: .3rem .85rem;
            font-size: .8rem;
            cursor: pointer;
            transition: all .2s;
        }
        .topbar-logout:hover {
            background: var(--mp-danger);
            border-color: var(--mp-danger);
        }

        /* ── NOTIFICATION BELL ───────────────────── */
        .notif-wrap {
            position: relative;
        }
        .notif-btn {
            background: transparent;
            border: 1px solid rgba(255,255,255,.22);
            color: #fff;
            width: 38px; height: 38px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.05rem;
            cursor: pointer;
            position: relative;
            transition: background .2s, border-color .2s;
            flex-shrink: 0;
        }
        .notif-btn:hover {
            background: rgba(255,255,255,.12);
            border-color: rgba(255,255,255,.45);
        }
        .notif-btn.has-unread {
            border-color: var(--mp-secondary);
        }
        .notif-badge {
            position: absolute;
            top: -6px; right: -6px;
            background: #e74c3c;
            color: #fff;
            font-size: .62rem;
            font-weight: 800;
            min-width: 18px; height: 18px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            padding: 0 4px;
            border: 2px solid var(--mp-dark);
            line-height: 1;
        }
        /* ── DROP-DOWN PANEL ─────────────────────── */
        .notif-panel {
            display: none;
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            width: 370px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 12px 48px rgba(0,0,0,.18);
            border: 1px solid var(--mp-border);
            z-index: 2000;
            overflow: hidden;
            animation: notifSlideIn .18s ease;
        }
        .notif-panel.open { display: block; }
        @@keyframes notifSlideIn {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .notif-panel-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 1.25rem .8rem;
            border-bottom: 1px solid var(--mp-border);
        }
        .notif-panel-title {
            font-weight: 700;
            font-size: .95rem;
            color: var(--mp-dark);
            display: flex; align-items: center; gap: .4rem;
        }
        .notif-panel-title i { color: var(--mp-accent); }
        .notif-mark-all-btn {
            background: none; border: none;
            color: var(--mp-accent);
            font-size: .8rem; font-weight: 600;
            cursor: pointer; padding: 0;
            transition: color .15s;
        }
        .notif-mark-all-btn:hover { color: var(--mp-primary); text-decoration: underline; }
        /* list */
        .notif-list {
            max-height: 390px;
            overflow-y: auto;
            scrollbar-width: thin;
        }
        .notif-list::-webkit-scrollbar { width: 4px; }
        .notif-list::-webkit-scrollbar-thumb { background: var(--mp-border); border-radius: 4px; }
        /* individual item */
        .notif-item {
            display: flex; align-items: flex-start; gap: .8rem;
            padding: .85rem 1.25rem;
            border-bottom: 1px solid var(--mp-border);
            cursor: pointer;
            transition: background .15s;
            position: relative;
        }
        .notif-item:last-child { border-bottom: none; }
        .notif-item:hover { background: var(--mp-light); }
        .notif-item.unread { background: #f0f8ff; }
        .notif-item.unread:hover { background: #e6f2fb; }
        /* coloured icon bubble */
        .notif-icon-bub {
            width: 38px; height: 38px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
            margin-top: 1px;
        }
        .notif-icon-bub.info    { background: #e0f0f7; color: var(--mp-primary); }
        .notif-icon-bub.success { background: #dcf5e9; color: var(--mp-success); }
        .notif-icon-bub.warning { background: #fef8e0; color: #a07c00; }
        .notif-icon-bub.danger  { background: #fde8e8; color: var(--mp-danger); }
        /* text */
        .notif-body  { flex: 1; min-width: 0; }
        .notif-msg   { font-size: .855rem; color: var(--mp-text); line-height: 1.45; word-break: break-word; }
        .notif-time  { font-size: .74rem; color: var(--mp-muted); margin-top: .25rem; display: flex; align-items: center; gap: .25rem; }
        /* unread dot */
        .notif-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--mp-accent);
            flex-shrink: 0;
            margin-top: 5px;
        }
        /* empty / loading */
        .notif-empty {
            text-align: center;
            padding: 2.5rem 1rem;
            color: var(--mp-muted);
        }
        .notif-empty i { font-size: 2.2rem; display: block; margin-bottom: .6rem; opacity: .5; }
        .notif-empty p { margin: 0; font-size: .875rem; }
        /* footer */
        .notif-panel-footer {
            padding: .55rem 1.25rem;
            border-top: 1px solid var(--mp-border);
            background: var(--mp-light);
            text-align: center;
            font-size: .78rem;
            color: var(--mp-muted);
        }
        /* loading spinner */
        .notif-loading {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--mp-muted);
            font-size: .875rem;
        }

        /* ── SIDEBAR ─────────────────────────────── */
        .sidebar {
            position: fixed;
            top: 62px; left: 0; bottom: 0;
            width: var(--sidebar-w);
            background: #fff;
            border-right: 1px solid var(--mp-border);
            overflow-y: auto;
            z-index: 1040;
            padding: 1.5rem 0 2rem;
        }
        .sidebar-section {
            padding: 0 1rem .5rem;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--mp-muted);
            margin-top: 1rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .6rem 1.25rem;
            color: var(--mp-text);
            text-decoration: none;
            font-size: .9rem;
            font-weight: 500;
            border-radius: 0;
            transition: all .15s;
            border-left: 3px solid transparent;
        }
        .sidebar-link i { font-size: 1rem; color: var(--mp-muted); }
        .sidebar-link:hover,
        .sidebar-link.active {
            background: var(--mp-light);
            color: var(--mp-primary);
            border-left-color: var(--mp-accent);
        }
        .sidebar-link:hover i,
        .sidebar-link.active i { color: var(--mp-accent); }

        /* ── MAIN CONTENT ────────────────────────── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            padding-top: 62px;
            min-height: 100vh;
        }
        .main-content {
            padding: 2rem 2.5rem;
            max-width: 1200px;
        }

        /* ── PAGE HEADER ─────────────────────────── */
        .page-header { margin-bottom: 1.75rem; }
        .page-header h1 {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            color: var(--mp-dark);
            margin: 0;
        }
        .page-header p { color: var(--mp-muted); margin: .25rem 0 0; font-size: .9rem; }

        /* ── CARDS ───────────────────────────────── */
        .mp-card {
            background: #fff;
            border: 1px solid var(--mp-border);
            border-radius: 12px;
            padding: 1.75rem;
            box-shadow: 0 2px 8px rgba(26,95,122,.06);
        }
        .mp-card-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 1.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--mp-border);
        }
        .mp-card-title {
            font-weight: 700; font-size: 1rem; color: var(--mp-dark);
            display: flex; align-items: center; gap: .5rem;
        }
        .mp-card-title i { color: var(--mp-accent); }

        /* ── STAT CARDS ──────────────────────────── */
        .stat-card {
            background: #fff; border: 1px solid var(--mp-border);
            border-radius: 12px; padding: 1.4rem 1.6rem;
            display: flex; align-items: center; gap: 1rem;
        }
        .stat-icon {
            width: 52px; height: 52px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; flex-shrink: 0;
        }
        .stat-icon.blue  { background: #e0f0f7; color: var(--mp-primary); }
        .stat-icon.teal  { background: #e0f7f5; color: var(--mp-accent);  }
        .stat-icon.green { background: #e0f7ec; color: var(--mp-success); }
        .stat-icon.amber { background: #fef8e0; color: #a07c00; }
        .stat-val { font-size: 1.75rem; font-weight: 700; color: var(--mp-dark); line-height: 1; }
        .stat-lbl { font-size: .8rem; color: var(--mp-muted); margin-top: .2rem; }

        /* ── TABLES ──────────────────────────────── */
        .mp-table { width: 100%; border-collapse: separate; border-spacing: 0; }
        .mp-table thead th {
            background: var(--mp-light); color: var(--mp-muted);
            font-size: .75rem; font-weight: 700; letter-spacing: .8px;
            text-transform: uppercase; padding: .75rem 1rem;
            border-bottom: 2px solid var(--mp-border);
        }
        .mp-table tbody tr { border-bottom: 1px solid var(--mp-border); transition: background .15s; }
        .mp-table tbody tr:hover { background: var(--mp-light); }
        .mp-table td { padding: .9rem 1rem; font-size: .9rem; vertical-align: middle; }
        .mp-table td:last-child { white-space: nowrap; }

        /* ── BADGES ──────────────────────────────── */
        .badge-active   { background:#dcf5e9; color:#1a7a4a; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-inactive { background:#fde8e8; color:#c0392b; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-role     { background:#e8f0fe; color:#1a5f7a; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }

        /* ── FORMS ───────────────────────────────── */
        .form-label { font-weight: 600; font-size: .875rem; color: var(--mp-dark); margin-bottom: .35rem; }
        .form-control, .form-select {
            border: 1.5px solid var(--mp-border); border-radius: 8px;
            padding: .55rem .85rem; font-size: .9rem; color: var(--mp-text);
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--mp-accent);
            box-shadow: 0 0 0 3px rgba(21,152,149,.12);
            outline: none;
        }
        .form-control.input-validation-error,
        .form-select.input-validation-error { border-color: var(--mp-danger); }

        /* ── BUTTONS ─────────────────────────────── */
        .btn-mp-primary {
            background: var(--mp-primary); color: #fff; border: none;
            border-radius: 8px; padding: .55rem 1.4rem;
            font-weight: 600; font-size: .9rem;
            transition: background .2s, transform .1s; cursor: pointer;
        }
        .btn-mp-primary:hover { background: var(--mp-accent); color: #fff; }
        .btn-mp-primary:active { transform: scale(.98); }
        .btn-mp-outline {
            background: transparent; color: var(--mp-primary);
            border: 1.5px solid var(--mp-primary); border-radius: 8px;
            padding: .5rem 1.3rem; font-weight: 600; font-size: .9rem;
            transition: all .2s; cursor: pointer; text-decoration: none;
            display: inline-flex; align-items: center; gap: .4rem;
        }
        .btn-mp-outline:hover { background: var(--mp-primary); color: #fff; }
        .btn-mp-danger {
            background: var(--mp-danger); color: #fff; border: none;
            border-radius: 8px; padding: .5rem 1.3rem;
            font-weight: 600; font-size: .9rem; cursor: pointer;
            transition: background .2s;
        }
        .btn-mp-danger:hover { background: #a93226; }
        .btn-icon {
            background: none; border: none; padding: .3rem .5rem;
            border-radius: 6px; cursor: pointer; font-size: 1rem;
            transition: background .15s;
        }
        .btn-icon:hover { background: var(--mp-light); }

        /* ── ALERTS ──────────────────────────────── */
        .mp-alert {
            border-radius: 10px; padding: .9rem 1.2rem; margin-bottom: 1.25rem;
            display: flex; align-items: flex-start; gap: .7rem; font-size: .9rem;
        }
        .mp-alert-success { background: #dcf5e9; color: #1a7a4a; border: 1px solid #a8e6c5; }
        .mp-alert-danger  { background: #fde8e8; color: #c0392b; border: 1px solid #f5b7b1; }
        .mp-alert-info    { background: #e0f0f7; color: var(--mp-primary); border: 1px solid #aed6e8; }

        /* ── SEARCH BAR ──────────────────────────── */
        .search-wrap { position: relative; }
        .search-wrap .bi-search {
            position: absolute; left: .85rem; top: 50%; transform: translateY(-50%);
            color: var(--mp-muted); font-size: .9rem;
        }
        .search-wrap input { padding-left: 2.4rem; }

        /* ── RESPONSIVE ──────────────────────────── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); transition: transform .3s; }
            .sidebar.open { transform: translateX(0); }
            .main-wrap { margin-left: 0; }
            .main-content { padding: 1.25rem; }
            .notif-panel { width: calc(100vw - 2rem); right: -0.5rem; }
        }

        /* ── AUTH PAGES (no sidebar) ─────────────── */
        .auth-page {
            min-height: 100vh; display: flex;
            align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--mp-dark) 0%, var(--mp-primary) 60%, var(--mp-accent) 100%);
        }
        .auth-card {
            background: #fff; border-radius: 16px; padding: 2.5rem;
            width: 100%; max-width: 440px; box-shadow: 0 20px 60px rgba(0,0,0,.25);
        }
        .auth-logo { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--mp-dark); text-align: center; margin-bottom: .25rem; }
        .auth-logo span { color: var(--mp-accent); }
        .auth-sub { text-align: center; color: var(--mp-muted); font-size: .875rem; margin-bottom: 2rem; }
        .auth-divider { border-top: 1px solid var(--mp-border); margin: 1.25rem 0; }
    </style>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ══ TOP BAR ══════════════════════════════════════════════════════════ -->
    <nav class="topbar">
        <a asp-controller="Home" asp-action="Index" class="topbar-brand">
            <span class="brand-dot"></span> MedicalPractice
        </a>

        <div class="topbar-right">
            <span class="topbar-user">
                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
            </span>

            <!-- ── NOTIFICATION BELL ───────────────────────────────────── -->
            <div class="notif-wrap" id="notifWrap">
                <button class="notif-btn" id="notifBtn"
                        type="button"
                        aria-label="Notifications"
                        aria-expanded="false"
                        onclick="notifToggle(event)">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notif-badge d-none" id="notifBadge">0</span>
                </button>

                <div class="notif-panel" id="notifPanel" role="dialog" aria-label="Notifications">
                    <!-- header -->
                    <div class="notif-panel-header">
                        <span class="notif-panel-title">
                            <i class="bi bi-bell-fill"></i> Notifications
                        </span>
                        <button class="notif-mark-all-btn" type="button" onclick="notifMarkAllRead()">
                            Mark all read
                        </button>
                    </div>

                    <!-- items injected by JS -->
                    <div class="notif-list" id="notifList">
                        <div class="notif-loading">
                            <i class="bi bi-arrow-repeat"></i> Loading…
                        </div>
                    </div>

                    <!-- footer summary -->
                    <div class="notif-panel-footer" id="notifFooter">&nbsp;</div>
                </div>
            </div>
            <!-- ── END BELL ──────────────────────────────────────────────── -->

            <a asp-controller="Account" asp-action="Profile"
               class="btn-mp-outline"
               style="padding:.3rem .8rem;font-size:.8rem;color:#fff;border-color:rgba(255,255,255,.3);">
                <i class="bi bi-person"></i> Profile
            </a>

            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="topbar-logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- ══ SIDEBAR ═════════════════════════════════════════════════════════ -->
    <aside class="sidebar">

        @if (User.IsInRole("Admin"))
        {
            <div class="sidebar-section">Admin Panel</div>
            <a asp-controller="Admin" asp-action="DashBoard"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "DashBoard" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Create" class="sidebar-link">
                <i class="bi bi-person-plus"></i> Add Employee
            </a>
        }
        else if (User.IsInRole("Assistant"))
        {
            <div class="sidebar-section">Assistant</div>
            <a asp-controller="Assistance" asp-action="DashBoard" class="sidebar-link">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Assistance" asp-action="Index" class="sidebar-link">
                <i class="bi bi-people"></i> Patients
            </a>
            <a asp-controller="Assistance" asp-action="Create" class="sidebar-link">
                <i class="bi bi-person-plus"></i> Add Patient
            </a>
        }
        else if (User.IsInRole("Doctor"))
        {
            <div class="sidebar-section">Doctor</div>
            <a asp-controller="Doctors" asp-action="DashBoard" class="sidebar-link">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Doctors" asp-action="PatientList" class="sidebar-link">
                <i class="bi bi-people"></i> Patient List
            </a>
        }
        else if (User.IsInRole("Receptionist"))
        {
            <div class="sidebar-section">Receptionist</div>
            <a asp-controller="Receptionist" asp-action="DashBoard" class="sidebar-link">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Receptionist" asp-action="DailySchedule" class="sidebar-link">
                <i class="bi bi-calendar-check"></i> Daily Schedule
            </a>
            <a asp-controller="Receptionist" asp-action="BookAppointment" class="sidebar-link">
                <i class="bi bi-calendar-plus"></i> Book Appointment
            </a>
            <a asp-controller="Receptionist" asp-action="RegisterPatient" class="sidebar-link">
                <i class="bi bi-person-plus"></i> Register Patient
            </a>
        }

        <div class="sidebar-section" style="margin-top:2rem;">Account</div>
        <a asp-controller="Account" asp-action="Profile" class="sidebar-link">
            <i class="bi bi-person-badge"></i> My Profile
        </a>
        <a asp-controller="Account" asp-action="ChangePassword" class="sidebar-link">
            <i class="bi bi-key"></i> Change Password
        </a>
        <a asp-controller="Account" asp-action="TwoFactorManage" class="sidebar-link">
            <i class="bi bi-shield-lock"></i> Two-Factor Auth
        </a>

    </aside>

    <!-- ══ MAIN ════════════════════════════════════════════════════════════ -->
    <div class="main-wrap">
        <div class="main-content">

            @if (TempData["Success"] != null)
            {
                <div class="mp-alert mp-alert-success">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="mp-alert mp-alert-info">
                    <i class="bi bi-info-circle-fill"></i> @TempData["Info"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mp-alert mp-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                </div>
            }

            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

@if (User.Identity?.IsAuthenticated == true)
{
<script>
// ════════════════════════════════════════════════════════════════════════════
// IN-APP NOTIFICATION BELL
// ════════════════════════════════════════════════════════════════════════════

(function () {
    'use strict';

    // ── DOM refs ──────────────────────────────────────────────────────────
    const wrap    = document.getElementById('notifWrap');
    const btn     = document.getElementById('notifBtn');
    const panel   = document.getElementById('notifPanel');
    const badge   = document.getElementById('notifBadge');
    const list    = document.getElementById('notifList');
    const footer  = document.getElementById('notifFooter');

    // CSRF token exposed in <meta> by the layout
    const csrf = () =>
        document.querySelector('meta[name="request-verification-token"]')?.content ?? '';

    let panelOpen  = false;
    let pollTimer  = null;

    // ── Toggle the panel ─────────────────────────────────────────────────
    window.notifToggle = function (e) {
        e.stopPropagation();
        panelOpen = !panelOpen;
        panel.classList.toggle('open', panelOpen);
        btn.setAttribute('aria-expanded', panelOpen);

        if (panelOpen) {
            renderList(); // fetch + paint immediately on open
        }
    };

    // Close when clicking outside the widget
    document.addEventListener('click', function (e) {
        if (wrap && !wrap.contains(e.target) && panelOpen) {
            panelOpen = false;
            panel.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
        }
    });

    // Close on Escape
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && panelOpen) {
            panelOpen = false;
            panel.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
        }
    });

    // ── Fetch unread count (runs every 60 s) ─────────────────────────────
    async function refreshCount() {
        try {
            const res  = await fetch('/Notifications/Count', { credentials: 'same-origin' });
            if (!res.ok) return;
            const data = await res.json();
            const n    = data.count ?? 0;

            if (n > 0) {
                badge.textContent = n > 99 ? '99+' : String(n);
                badge.classList.remove('d-none');
                btn.classList.add('has-unread');
            } else {
                badge.classList.add('d-none');
                btn.classList.remove('has-unread');
            }
        } catch (_) { /* silent – network blip */ }
    }

    // ── Fetch & render the notification list ─────────────────────────────
    async function renderList() {
        list.innerHTML = '<div class="notif-loading"><i class="bi bi-arrow-repeat"></i> Loading…</div>';

        try {
            const res   = await fetch('/Notifications/Recent', { credentials: 'same-origin' });
            if (!res.ok) throw new Error('fetch failed');
            const items = await res.json();

            if (!items || items.length === 0) {
                list.innerHTML = `
                    <div class="notif-empty">
                        <i class="bi bi-bell-slash"></i>
                        <p>You're all caught up!</p>
                    </div>`;
                footer.textContent = 'No notifications';
                return;
            }

            const unreadCount = items.filter(n => !n.isRead).length;
            footer.textContent = unreadCount > 0
                ? `${unreadCount} unread notification${unreadCount !== 1 ? 's' : ''}`
                : 'All notifications are read';

            list.innerHTML = items.map(n => `
                <div class="notif-item ${n.isRead ? '' : 'unread'}"
                     data-id="${n.notificationId}"
                     data-link="${escHtml(n.link ?? '')}"
                     onclick="notifItemClick(this)">
                    <div class="notif-icon-bub ${escHtml(n.type)}">
                        <i class="bi ${escHtml(n.icon)}"></i>
                    </div>
                    <div class="notif-body">
                        <div class="notif-msg">${escHtml(n.message)}</div>
                        <div class="notif-time">
                            <i class="bi bi-clock"></i>${escHtml(n.timeAgo)}
                        </div>
                    </div>
                    ${!n.isRead ? '<div class="notif-dot"></div>' : ''}
                </div>`).join('');

        } catch (_) {
            list.innerHTML = `
                <div class="notif-empty">
                    <i class="bi bi-wifi-off"></i>
                    <p>Could not load notifications.</p>
                </div>`;
        }
    }

    // ── Click a single notification ───────────────────────────────────────
    window.notifItemClick = async function (el) {
        const id   = parseInt(el.dataset.id, 10);
        const link = el.dataset.link;

        // Optimistically mark as read in the UI
        el.classList.remove('unread');
        const dot = el.querySelector('.notif-dot');
        if (dot) dot.remove();

        // POST mark-read (fire-and-forget)
        try {
            await fetch(`/Notifications/MarkRead/${id}`, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'RequestVerificationToken': csrf() }
            });
        } catch (_) { /* silent */ }

        await refreshCount();

        if (link && link.trim() !== '') {
            window.location.href = link;
        } else {
            // just repaint the footer count
            const stillUnread = list.querySelectorAll('.notif-item.unread').length;
            footer.textContent = stillUnread > 0
                ? `${stillUnread} unread notification${stillUnread !== 1 ? 's' : ''}`
                : 'All notifications are read';
        }
    };

    // ── Mark ALL as read ──────────────────────────────────────────────────
    window.notifMarkAllRead = async function () {
        try {
            await fetch('/Notifications/MarkAllRead', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'RequestVerificationToken': csrf() }
            });
        } catch (_) { /* silent */ }

        // Repaint locally without another round-trip for snappiness
        list.querySelectorAll('.notif-item.unread').forEach(el => {
            el.classList.remove('unread');
            const dot = el.querySelector('.notif-dot');
            if (dot) dot.remove();
        });
        footer.textContent = 'All notifications are read';
        badge.classList.add('d-none');
        btn.classList.remove('has-unread');
    };

    // ── Utility: HTML-escape ──────────────────────────────────────────────
    function escHtml(str) {
        const d = document.createElement('div');
        d.textContent = String(str ?? '');
        return d.innerHTML;
    }

    // ── Bootstrap: initial count fetch + start polling ────────────────────
    refreshCount();
    pollTimer = setInterval(refreshCount, 60_000); // every 60 seconds

})();
</script>
}

</body>
</html>
