<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – MedicalPractice</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />

    <style>
        :root {
            --mp-primary:   #1a5f7a;
            --mp-secondary: #57c5b6;
            --mp-accent:    #159895;
            --mp-light:     #f4f9fb;
            --mp-dark:      #0d3d4d;
            --mp-text:      #1e2a2e;
            --mp-muted:     #6b8a93;
            --mp-border:    #d0e6ed;
            --mp-danger:    #c0392b;
            --mp-success:   #1a7a4a;
            --sidebar-w:    260px;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--mp-light);
            color: var(--mp-text);
            min-height: 100vh;
        }

        /* ── TOP NAV ─────────────────────────────── */
        .topbar {
            background: var(--mp-dark);
            height: 62px;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1050;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
        }
        .topbar-brand {
            font-family: 'DM Serif Display', serif;
            font-size: 1.25rem;
            color: #fff;
            text-decoration: none;
            letter-spacing: .4px;
            display: flex;
            align-items: center;
            gap: .6rem;
        }
        .topbar-brand .brand-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
            background: var(--mp-secondary);
            display: inline-block;
        }
        .topbar-brand:hover { color: var(--mp-secondary); }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .topbar-user {
            color: #cde8ef;
            font-size: .875rem;
            font-weight: 500;
        }
        .topbar-logout {
            background: transparent;
            border: 1px solid rgba(255,255,255,.25);
            color: #fff;
            border-radius: 6px;
            padding: .3rem .85rem;
            font-size: .8rem;
            cursor: pointer;
            transition: all .2s;
        }
        .topbar-logout:hover {
            background: var(--mp-danger);
            border-color: var(--mp-danger);
        }

        /* ── SIDEBAR ─────────────────────────────── */
        .sidebar {
            position: fixed;
            top: 62px; left: 0; bottom: 0;
            width: var(--sidebar-w);
            background: #fff;
            border-right: 1px solid var(--mp-border);
            overflow-y: auto;
            z-index: 1040;
            padding: 1.5rem 0 2rem;
        }
        .sidebar-section {
            padding: 0 1rem .5rem;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--mp-muted);
            margin-top: 1rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .6rem 1.25rem;
            color: var(--mp-text);
            text-decoration: none;
            font-size: .9rem;
            font-weight: 500;
            border-radius: 0;
            transition: all .15s;
            border-left: 3px solid transparent;
        }
        .sidebar-link i { font-size: 1rem; color: var(--mp-muted); }
        .sidebar-link:hover,
        .sidebar-link.active {
            background: var(--mp-light);
            color: var(--mp-primary);
            border-left-color: var(--mp-accent);
        }
        .sidebar-link:hover i,
        .sidebar-link.active i { color: var(--mp-accent); }

        /* ── MAIN CONTENT ────────────────────────── */
        .main-wrap {
            margin-left: var(--sidebar-w);
            padding-top: 62px;
            min-height: 100vh;
        }
        .main-content {
            padding: 2rem 2.5rem;
            max-width: 1200px;
        }

        /* ── PAGE HEADER ─────────────────────────── */
        .page-header {
            margin-bottom: 1.75rem;
        }
        .page-header h1 {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            color: var(--mp-dark);
            margin: 0;
        }
        .page-header p {
            color: var(--mp-muted);
            margin: .25rem 0 0;
            font-size: .9rem;
        }

        /* ── CARDS ───────────────────────────────── */
        .mp-card {
            background: #fff;
            border: 1px solid var(--mp-border);
            border-radius: 12px;
            padding: 1.75rem;
            box-shadow: 0 2px 8px rgba(26,95,122,.06);
        }
        .mp-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--mp-border);
        }
        .mp-card-title {
            font-weight: 700;
            font-size: 1rem;
            color: var(--mp-dark);
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .mp-card-title i { color: var(--mp-accent); }

        /* ── STAT CARDS ──────────────────────────── */
        .stat-card {
            background: #fff;
            border: 1px solid var(--mp-border);
            border-radius: 12px;
            padding: 1.4rem 1.6rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .stat-icon {
            width: 52px; height: 52px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }
        .stat-icon.blue  { background: #e0f0f7; color: var(--mp-primary); }
        .stat-icon.teal  { background: #e0f7f5; color: var(--mp-accent);  }
        .stat-icon.green { background: #e0f7ec; color: var(--mp-success); }
        .stat-icon.amber { background: #fef8e0; color: #a07c00; }
        .stat-val { font-size: 1.75rem; font-weight: 700; color: var(--mp-dark); line-height: 1; }
        .stat-lbl { font-size: .8rem; color: var(--mp-muted); margin-top: .2rem; }

        /* ── TABLES ──────────────────────────────── */
        .mp-table { width: 100%; border-collapse: separate; border-spacing: 0; }
        .mp-table thead th {
            background: var(--mp-light);
            color: var(--mp-muted);
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            padding: .75rem 1rem;
            border-bottom: 2px solid var(--mp-border);
        }
        .mp-table tbody tr {
            border-bottom: 1px solid var(--mp-border);
            transition: background .15s;
        }
        .mp-table tbody tr:hover { background: var(--mp-light); }
        .mp-table td { padding: .9rem 1rem; font-size: .9rem; vertical-align: middle; }
        .mp-table td:last-child { white-space: nowrap; }

        /* ── BADGES ──────────────────────────────── */
        .badge-active   { background:#dcf5e9; color:#1a7a4a; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-inactive { background:#fde8e8; color:#c0392b; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-role     { background:#e8f0fe; color:#1a5f7a; padding:.35rem .7rem; border-radius:20px; font-size:.75rem; font-weight:600; }

        /* ── FORMS ───────────────────────────────── */
        .form-label { font-weight: 600; font-size: .875rem; color: var(--mp-dark); margin-bottom: .35rem; }
        .form-control, .form-select {
            border: 1.5px solid var(--mp-border);
            border-radius: 8px;
            padding: .55rem .85rem;
            font-size: .9rem;
            color: var(--mp-text);
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--mp-accent);
            box-shadow: 0 0 0 3px rgba(21,152,149,.12);
            outline: none;
        }
        .form-control.input-validation-error,
        .form-select.input-validation-error { border-color: var(--mp-danger); }

        /* ── BUTTONS ─────────────────────────────── */
        .btn-mp-primary {
            background: var(--mp-primary);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .55rem 1.4rem;
            font-weight: 600;
            font-size: .9rem;
            transition: background .2s, transform .1s;
            cursor: pointer;
        }
        .btn-mp-primary:hover { background: var(--mp-accent); color: #fff; }
        .btn-mp-primary:active { transform: scale(.98); }
        .btn-mp-outline {
            background: transparent;
            color: var(--mp-primary);
            border: 1.5px solid var(--mp-primary);
            border-radius: 8px;
            padding: .5rem 1.3rem;
            font-weight: 600;
            font-size: .9rem;
            transition: all .2s;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
        }
        .btn-mp-outline:hover { background: var(--mp-primary); color: #fff; }
        .btn-mp-danger {
            background: var(--mp-danger);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .5rem 1.3rem;
            font-weight: 600;
            font-size: .9rem;
            cursor: pointer;
            transition: background .2s;
        }
        .btn-mp-danger:hover { background: #a93226; }
        .btn-icon {
            background: none;
            border: none;
            padding: .3rem .5rem;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
            transition: background .15s;
        }
        .btn-icon:hover { background: var(--mp-light); }

        /* ── ALERTS ──────────────────────────────── */
        .mp-alert {
            border-radius: 10px;
            padding: .9rem 1.2rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: .7rem;
            font-size: .9rem;
        }
        .mp-alert-success { background: #dcf5e9; color: #1a7a4a; border: 1px solid #a8e6c5; }
        .mp-alert-danger  { background: #fde8e8; color: #c0392b; border: 1px solid #f5b7b1; }
        .mp-alert-info    { background: #e0f0f7; color: var(--mp-primary); border: 1px solid #aed6e8; }

        /* ── SEARCH BAR ──────────────────────────── */
        .search-wrap { position: relative; }
        .search-wrap .bi-search {
            position: absolute; left: .85rem; top: 50%; transform: translateY(-50%);
            color: var(--mp-muted); font-size: .9rem;
        }
        .search-wrap input { padding-left: 2.4rem; }

        /* ── RESPONSIVE ──────────────────────────── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); transition: transform .3s; }
            .sidebar.open { transform: translateX(0); }
            .main-wrap { margin-left: 0; }
            .main-content { padding: 1.25rem; }
        }

        /* ── AUTH PAGES (no sidebar) ─────────────── */
        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--mp-dark) 0%, var(--mp-primary) 60%, var(--mp-accent) 100%);
        }
        .auth-card {
            background: #fff;
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 20px 60px rgba(0,0,0,.25);
        }
        .auth-logo {
            font-family: 'DM Serif Display', serif;
            font-size: 1.6rem;
            color: var(--mp-dark);
            text-align: center;
            margin-bottom: .25rem;
        }
        .auth-logo span { color: var(--mp-accent); }
        .auth-sub { text-align: center; color: var(--mp-muted); font-size: .875rem; margin-bottom: 2rem; }
        .auth-divider { border-top: 1px solid var(--mp-border); margin: 1.25rem 0; }
    </style>
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- TOP BAR -->
    <nav class="topbar">
        <a asp-controller="Home" asp-action="Index" class="topbar-brand">
            <span class="brand-dot"></span> MedicalPractice
        </a>
        <div class="topbar-right">
            <span class="topbar-user">
                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
            </span>
            <a asp-controller="Account" asp-action="Profile" class="btn-mp-outline" style="padding:.3rem .8rem;font-size:.8rem;color:#fff;border-color:rgba(255,255,255,.3);">
                <i class="bi bi-person"></i> Profile
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="topbar-logout">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </div>
    </nav>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        @if (User.IsInRole("Admin"))
        {
            <div class="sidebar-section">Admin Panel</div>
            <a asp-controller="Admin" asp-action="DashBoard" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Create" class="sidebar-link">
                <i class="bi bi-person-plus"></i> Add Employee
            </a>
        }
        else if (User.IsInRole("Assistant"))
        {
            <div class="sidebar-section">Assistant</div>
            <a asp-controller="Assistance" asp-action="DashBoard" class="sidebar-link">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Assistance" asp-action="Index" class="sidebar-link">
                <i class="bi bi-people"></i> Patients
            </a>
            <a asp-controller="Assistance" asp-action="Create" class="sidebar-link">
                <i class="bi bi-person-plus"></i> Add Patient
            </a>
        }
        else if (User.IsInRole("Doctor"))
        {
            <div class="sidebar-section">Doctor</div>
            <a asp-controller="Doctors" asp-action="DashBoard" class="sidebar-link">
                <i class="bi bi-grid"></i> Dashboard
            </a>
            <a asp-controller="Doctors" asp-action="PatientList" class="sidebar-link">
                <i class="bi bi-people"></i> Patient List
            </a>
        }

        <div class="sidebar-section" style="margin-top:2rem;">Account</div>
        <a asp-controller="Account" asp-action="Profile" class="sidebar-link">
            <i class="bi bi-person-badge"></i> My Profile
        </a>
        <a asp-controller="Account" asp-action="ChangePassword" class="sidebar-link">
            <i class="bi bi-key"></i> Change Password
        </a>
        <a asp-controller="Account" asp-action="TwoFactorManage" class="sidebar-link">
            <i class="bi bi-shield-lock"></i> Two-Factor Auth
        </a>
    </aside>

    <!-- MAIN -->
    <div class="main-wrap">
        <div class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="mp-alert mp-alert-success">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="mp-alert mp-alert-info">
                    <i class="bi bi-info-circle-fill"></i> @TempData["Info"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="mp-alert mp-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                </div>
            }
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
