@{
    ViewData["Title"] = "Assistant Dashboard";
}

<div class="page-header">
    <h1>Assistant Dashboard</h1>
    <p>Manage patients in the medical practice system</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <a asp-action="Index" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid var(--mp-primary); transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(26,95,122,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:var(--mp-primary); margin-bottom:.75rem;"><i class="bi bi-people"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">View All Patients</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Browse, search and manage patients</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="Create" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid var(--mp-accent); transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(21,152,149,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:var(--mp-accent); margin-bottom:.75rem;"><i class="bi bi-person-plus"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Add New Patient</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Register a new patient in the system</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="Index" asp-route-searchString="" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid #a07c00; transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(160,124,0,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:#a07c00; margin-bottom:.75rem;"><i class="bi bi-search"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Search Patients</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Find patients by name or username</div>
            </div>
        </a>
    </div>
</div>

<div class="mp-card mt-4">
    <div class="mp-card-header">
        <div class="mp-card-title"><i class="bi bi-info-circle"></i> Quick Start</div>
    </div>
    <div style="color:var(--mp-muted); font-size:.9rem; line-height:1.8;">
        <p><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i>Use <strong>Add New Patient</strong> to register patients with their personal and medical aid information.</p>
        <p><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i>Use <strong>View All Patients</strong> to edit, update or delete patient records.</p>
        <p class="mb-0"><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i>Search patients by <strong>name</strong>, <strong>surname</strong>, or <strong>username</strong>.</p>
    </div>
</div>
