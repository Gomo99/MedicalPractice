@{
    ViewData["Title"] = "Two-Factor Authentication";
    bool isEnabled = (bool)(ViewData["IsEnabled"] ?? false);
    int codesLeft = (int)(ViewData["CodesLeft"] ?? 0);
}

<div class="page-header">
    <h1><i class="bi bi-shield-lock me-2" style="color:var(--mp-accent);"></i>Two-Factor Authentication</h1>
    <p>Manage your two-factor authentication settings</p>
</div>

<div style="max-width:600px;">
    <div class="mp-card">
        <div style="display:flex; align-items:center; gap:1.25rem; margin-bottom:1.5rem;">
            <div style="width:56px;height:56px;border-radius:12px;display:flex;align-items:center;justify-content:center;
                        font-size:1.5rem; @(isEnabled ? "background:#e0f7ec;color:var(--mp-success);" : "background:#fde8e8;color:var(--mp-danger);")">
                <i class="bi @(isEnabled ? "bi-shield-check" : "bi-shield-x")"></i>
            </div>
            <div>
                <div style="font-weight:700; font-size:1.05rem;">
                    Two-Factor Authentication is
                    @if (isEnabled) { <span style="color:var(--mp-success);">Enabled</span> }
                    else { <span style="color:var(--mp-danger);">Disabled</span> }
                </div>
                <div style="font-size:.875rem; color:var(--mp-muted);">
                    @if (isEnabled)
                    { <span>Your account is secured with an authenticator app.</span> }
                    else
                    { <span>Enable 2FA for an extra layer of security.</span> }
                </div>
            </div>
        </div>

        @if (!isEnabled)
        {
            <a asp-action="TwoFactorSetup" class="btn-mp-primary d-inline-flex align-items-center gap-2" style="text-decoration:none;">
                <i class="bi bi-shield-plus"></i> Enable Two-Factor Authentication
            </a>
        }
        else
        {
            <div class="auth-divider"></div>

            <!-- Recovery codes status -->
            <div style="background:var(--mp-light); border-radius:10px; padding:1.1rem 1.25rem; margin-bottom:1.25rem;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <div style="font-weight:600; font-size:.95rem;">Recovery Codes</div>
                        <div style="font-size:.825rem; color:@(codesLeft <= 2 ? "var(--mp-danger)" : "var(--mp-muted)");">
                            @codesLeft code@(codesLeft != 1 ? "s" : "") remaining
                            @if (codesLeft <= 2)
                            { <strong> — generate new codes soon!</strong> }
                        </div>
                    </div>
                    <form asp-action="TwoFactorRegenerateCodes" method="post" onsubmit="return confirm('Generate new recovery codes? Your existing codes will be invalidated.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-mp-outline" style="font-size:.8rem; padding:.35rem .9rem;">
                            <i class="bi bi-arrow-clockwise"></i> Regenerate
                        </button>
                    </form>
                </div>
            </div>

            <!-- Disable 2FA -->
            <div style="border:1px solid #f5b7b1; border-radius:10px; padding:1.1rem 1.25rem; background:#fff9f9;">
                <div style="font-weight:600; color:var(--mp-danger); margin-bottom:.4rem;">Disable Two-Factor Authentication</div>
                <p style="font-size:.85rem; color:var(--mp-muted); margin-bottom:1rem;">
                    Disabling 2FA will remove the extra security from your account.
                </p>
                <form asp-action="TwoFactorDisable" method="post" onsubmit="return confirm('Are you sure you want to disable 2FA? This will reduce your account security.');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-mp-danger" style="font-size:.875rem;">
                        <i class="bi bi-shield-x me-1"></i> Disable 2FA
                    </button>
                </form>
            </div>
        }
    </div>
</div>
