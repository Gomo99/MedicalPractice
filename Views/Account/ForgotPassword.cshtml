@model MedicalPractice.ViewModel.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">Medical<span>Practice</span></div>
        <p class="auth-sub">Enter your email and we'll send you a reset PIN</p>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mp-alert mp-alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span asp-validation-summary="ModelOnly"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--mp-muted);"></i>
                    <input asp-for="Email" class="form-control" style="padding-left:2.4rem;" placeholder="your@email.com" type="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <button type="submit" class="btn-mp-primary w-100" style="padding:.7rem;">
                <i class="bi bi-send me-2"></i>Send Reset PIN
            </button>
        </form>

        <div class="auth-divider"></div>
        <div class="text-center">
            <a asp-action="Login" style="color:var(--mp-accent); text-decoration:none; font-size:.875rem; font-weight:500;">
                <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
