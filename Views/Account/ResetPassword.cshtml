@model MedicalPractice.ViewModel.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">Medical<span>Practice</span></div>
        <p class="auth-sub">Enter the PIN sent to your email and choose a new password</p>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mp-alert mp-alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span asp-validation-summary="ModelOnly"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div style="position:relative;">
                    <i class="bi bi-envelope" style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--mp-muted);"></i>
                    <input asp-for="Email" class="form-control" style="padding-left:2.4rem;" placeholder="your@email.com" type="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Pin" class="form-label">Reset PIN</label>
                <input asp-for="Pin" class="form-control" placeholder="6-digit PIN from email" maxlength="6"
                       style="letter-spacing:6px; font-size:1.2rem; text-align:center; font-weight:700;" />
                <span asp-validation-for="Pin" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="New password" />
                <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <button type="submit" class="btn-mp-primary w-100" style="padding:.7rem;">
                <i class="bi bi-shield-check me-2"></i>Reset Password
            </button>
        </form>

        <div class="auth-divider"></div>
        <div class="text-center">
            <a asp-action="Login" style="color:var(--mp-accent); text-decoration:none; font-size:.875rem; font-weight:500;">
                <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
