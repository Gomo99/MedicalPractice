@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card text-center">
        <div style="width:72px;height:72px;border-radius:50%;background:#e0f0f7;display:flex;align-items:center;
                    justify-content:center;margin:0 auto 1.25rem;font-size:2rem;color:var(--mp-primary);">
            <i class="bi bi-envelope-check"></i>
        </div>
        <div class="auth-logo">Check Your Email</div>
        <p class="auth-sub" style="margin-top:.5rem;">
            @if (TempData["Info"] != null)
            {
                @TempData["Info"]
            }
            else
            {
                <span>If that email is registered, a reset PIN has been sent. The PIN expires in <strong>15 minutes</strong>.</span>
            }
        </p>

        <a asp-action="ResetPassword" class="btn-mp-primary d-block" style="text-decoration:none; padding:.7rem;">
            <i class="bi bi-key me-2"></i>Enter Reset PIN
        </a>

        <div class="auth-divider"></div>
        <a asp-action="Login" style="color:var(--mp-accent); text-decoration:none; font-size:.875rem; font-weight:500;">
            <i class="bi bi-arrow-left me-1"></i> Back to Login
        </a>
    </div>
</div>
