@model MedicalPractice.ViewModel.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <h1><i class="bi bi-key me-2" style="color:var(--mp-accent);"></i>Change Password</h1>
    <p>Update your account password</p>
</div>

<div style="max-width:480px;">
    <div class="mp-card">
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="mp-alert mp-alert-danger" style="@(ViewData.ModelState.ErrorCount == 0 ? "display:none" : "")">
                <i class="bi bi-exclamation-circle-fill"></i>
                <div><asp:ValidationSummary /></div>
            </div>

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="Enter current password" />
                <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label">New Password</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="Enter new password" id="newPwd" />
                <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <!-- Password strength meter -->
            <div class="mb-4">
                <div style="font-size:.8rem; color:var(--mp-muted); margin-bottom:.4rem;">Password strength</div>
                <div style="height:5px; border-radius:3px; background:var(--mp-border); overflow:hidden;">
                    <div id="strengthBar" style="height:100%; width:0%; background:var(--mp-danger); transition:width .3s, background .3s;"></div>
                </div>
                <div id="strengthText" style="font-size:.78rem; margin-top:.3rem; color:var(--mp-muted);"></div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-mp-primary flex-grow-1">
                    <i class="bi bi-check-lg me-1"></i> Update Password
                </button>
                <a asp-action="Profile" class="btn-mp-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('newPwd').addEventListener('input', function () {
            const val = this.value;
            const bar = document.getElementById('strengthBar');
            const txt = document.getElementById('strengthText');
            let score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;
            const levels = [
                { w: '0%', c: '#c0392b', t: '' },
                { w: '25%', c: '#c0392b', t: 'Weak' },
                { w: '50%', c: '#e67e22', t: 'Fair' },
                { w: '75%', c: '#f1c40f', t: 'Good' },
                { w: '100%', c: '#1a7a4a', t: 'Strong' }
            ];
            const l = levels[score];
            bar.style.width = l.w;
            bar.style.background = l.c;
            txt.textContent = l.t;
            txt.style.color = l.c;
        });
    </script>
}
