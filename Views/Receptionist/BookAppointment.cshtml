@model MedicalPractice.ViewModel.AppointmentViewModel
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2" style="color:var(--mp-accent);"></i>Book Appointment</h1>
    <p>Schedule a new patient appointment</p>
</div>

<div style="max-width:720px;">
    <div class="mp-card">
        <form asp-action="BookAppointment" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mp-alert mp-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="PatientId" class="form-label">Patient <span style="color:var(--mp-danger);">*</span></label>
                    <select asp-for="PatientId" class="form-select" asp-items="@Model.Patients">
                        <option value="">— Select patient —</option>
                    </select>
                    <span asp-validation-for="PatientId" class="text-danger" style="font-size:.8rem;"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DoctorId" class="form-label">Doctor <span style="color:var(--mp-danger);">*</span></label>
                    <select asp-for="DoctorId" class="form-select" asp-items="@Model.Doctors">
                        <option value="">— Select doctor —</option>
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger" style="font-size:.8rem;"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AppointmentDateTime" class="form-label">Date & Time <span style="color:var(--mp-danger);">*</span></label>
                    <input asp-for="AppointmentDateTime" class="form-control" type="datetime-local"
                           value="@Model.AppointmentDateTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="AppointmentDateTime" class="text-danger" style="font-size:.8rem;"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Reason" class="form-label">Reason <span style="color:var(--mp-danger);">*</span></label>
                    <input asp-for="Reason" class="form-control" placeholder="e.g. Consultation, Follow-up" />
                    <span asp-validation-for="Reason" class="text-danger" style="font-size:.8rem;"></span>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-mp-primary flex-grow-1">
                    <i class="bi bi-calendar-check me-1"></i> Book Appointment
                </button>
                <a asp-action="DailySchedule" class="btn-mp-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}