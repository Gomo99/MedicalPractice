@{
    ViewData["Title"] = "Receptionist Dashboard";
}

<div class="page-header">
    <h1><i class="bi bi-reception-4 me-2" style="color:var(--mp-accent);"></i>Reception Desk</h1>
    <p>Manage appointments & patient registration</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <a asp-action="DailySchedule" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid var(--mp-primary); transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(26,95,122,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:var(--mp-primary); margin-bottom:.75rem;"><i class="bi bi-calendar-check"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Today's Schedule</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">View & manage all appointments for today</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="BookAppointment" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid var(--mp-accent); transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(21,152,149,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:var(--mp-accent); margin-bottom:.75rem;"><i class="bi bi-plus-circle"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Book Appointment</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Schedule a new appointment for a patient</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="DoctorSchedule" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid #a07c00; transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(160,124,0,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:#a07c00; margin-bottom:.75rem;"><i class="bi bi-person-badge"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Doctor Availability</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Check a doctor's daily schedule</div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-action="RegisterPatient" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid #6c757d; transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(108,117,125,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="font-size:2rem; color:#6c757d; margin-bottom:.75rem;"><i class="bi bi-person-plus"></i></div>
                <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Register Patient</div>
                <div style="color:var(--mp-muted); font-size:.875rem; margin-top:.3rem;">Add a new patient to the system</div>
            </div>
        </a>
    </div>
</div>

<div class="mp-card mt-4">
    <div class="mp-card-header">
        <div class="mp-card-title"><i class="bi bi-info-circle"></i> Quick Guide</div>
    </div>
    <div style="color:var(--mp-muted); font-size:.9rem; line-height:1.8;">
        <p><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i>Use <strong>Today's Schedule</strong> to check-in patients, cancel or reschedule appointments.</p>
        <p><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i><strong>Book Appointment</strong> requires selecting a patient and a doctor.</p>
        <p><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i><strong>Doctor Availability</strong> shows non‑cancelled appointments for a chosen doctor and date.</p>
        <p class="mb-0"><i class="bi bi-check2 me-2" style="color:var(--mp-accent);"></i>You can also quickly <strong>Register a Patient</strong> before booking.</p>
    </div>
</div>