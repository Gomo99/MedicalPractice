@model MedicalPractice.ViewModel.AppointmentViewModel
@{
    ViewData["Title"] = "Reschedule Appointment";
    string patientName = ViewBag.PatientName as string ?? "Unknown";
    string doctorName = ViewBag.DoctorName as string ?? "Unknown";
}

<div class="page-header">
    <h1><i class="bi bi-calendar2-week me-2" style="color:var(--mp-accent);"></i>Reschedule</h1>
    <p>Change appointment date/time</p>
</div>

<div style="max-width:600px;">
    <div class="mp-card">
        <!-- Appointment info display -->
        <div style="background:var(--mp-light); border-radius:10px; padding:1.25rem; margin-bottom:1.5rem;">
            <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem;">
                <div>
                    <div style="font-weight:700;">Patient: @patientName</div>
                    <div style="color:var(--mp-muted);">Doctor: @doctorName</div>
                    <div class="mt-1"><strong>Reason:</strong> @Model.Reason</div>
                </div>
            </div>
        </div>

        <form asp-action="Reschedule" asp-route-id="@Model.AppointmentId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AppointmentId" />
            <input type="hidden" asp-for="PatientId" />
            <input type="hidden" asp-for="DoctorId" />
            <input type="hidden" asp-for="Reason" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mp-alert mp-alert-danger">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="AppointmentDateTime" class="form-label">New Date & Time <span style="color:var(--mp-danger);">*</span></label>
                <input asp-for="AppointmentDateTime" class="form-control" type="datetime-local"
                       value="@Model.AppointmentDateTime.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="AppointmentDateTime" class="text-danger" style="font-size:.8rem;"></span>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-mp-primary flex-grow-1">
                    <i class="bi bi-arrow-repeat me-1"></i> Reschedule
                </button>
                <a asp-action="DailySchedule" class="btn-mp-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}