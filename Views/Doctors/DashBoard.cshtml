@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="page-header">
    <h1>Doctor Dashboard</h1>
    <p>Welcome back, Dr. @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <a asp-action="PatientList" style="text-decoration:none;">
            <div class="mp-card" style="border-left:4px solid var(--mp-primary); transition:transform .2s, box-shadow .2s; cursor:pointer;"
                 onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 6px 20px rgba(26,95,122,.15)';"
                 onmouseout="this.style.transform='';this.style.boxShadow='';">
                <div style="display:flex; align-items:center; gap:1rem;">
                    <div style="width:56px;height:56px;border-radius:12px;background:#e0f0f7;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--mp-primary);">
                        <i class="bi bi-people"></i>
                    </div>
                    <div>
                        <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Patient List</div>
                        <div style="color:var(--mp-muted); font-size:.875rem;">View and search all patients</div>
                    </div>
                    <i class="bi bi-arrow-right ms-auto" style="color:var(--mp-muted);"></i>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <div class="mp-card" style="border-left:4px solid var(--mp-secondary);">
            <div style="display:flex; align-items:center; gap:1rem;">
                <div style="width:56px;height:56px;border-radius:12px;background:#e0f7f5;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--mp-accent);">
                    <i class="bi bi-clipboard2-pulse"></i>
                </div>
                <div>
                    <div style="font-weight:700; font-size:1.05rem; color:var(--mp-dark);">Visit Records</div>
                    <div style="color:var(--mp-muted); font-size:.875rem;">Select a patient to view or add visits</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mp-card mt-4">
    <div class="mp-card-header">
        <div class="mp-card-title"><i class="bi bi-search"></i> Quick Patient Search</div>
    </div>
    <form asp-controller="Doctors" asp-action="PatientList" method="get">
        <div class="d-flex gap-2" style="max-width:460px;">
            <div class="search-wrap flex-grow-1">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" class="form-control"
                       placeholder="Patient number, name, surname or username…" />
            </div>
            <button type="submit" class="btn-mp-primary">Search</button>
        </div>
    </form>
</div>
