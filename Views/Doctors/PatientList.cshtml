@model IEnumerable<MedicalPractice.Models.Patient>
@{
    ViewData["Title"] = "Patient List";
    string filter = ViewData["CurrentFilter"]?.ToString() ?? "";
}

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-3">
    <div>
        <h1><i class="bi bi-people me-2" style="color:var(--mp-accent);"></i>Patient List</h1>
        <p>@Model.Count() patient@(Model.Count() != 1 ? "s" : "") found@(string.IsNullOrEmpty(filter) ? "" : $" for \"{filter}\"")</p>
    </div>
</div>

<!-- Search Bar -->
<form asp-action="PatientList" method="get" class="mb-4">
    <div class="d-flex gap-2" style="max-width:480px;">
        <div class="search-wrap flex-grow-1">
            <i class="bi bi-search"></i>
            <input type="text" name="searchString" class="form-control" value="@filter"
                   placeholder="Search by patient #, name, surname or username…" />
        </div>
        <button type="submit" class="btn-mp-primary" style="padding:.55rem 1.1rem;">Search</button>
        @if (!string.IsNullOrEmpty(filter))
        {
            <a asp-action="PatientList" class="btn-mp-outline">Clear</a>
        }
    </div>
</form>

<div class="mp-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-person-x" style="font-size:3rem; color:var(--mp-border);"></i>
            <p style="color:var(--mp-muted); margin-top:.75rem;">
                @(string.IsNullOrEmpty(filter) ? "No patients in the system yet." : $"No results for \"{filter}\".")
            </p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Patient #</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Gender</th>
                        <th>Medical Aid</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>
                                <span style="background:var(--mp-light);border:1px solid var(--mp-border);border-radius:6px;padding:.2rem .6rem;font-family:monospace;font-size:.8rem;">
                                    #@p.PatientId.ToString("D4")
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:.65rem;">
                                    <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#e0f0f7,var(--mp-secondary));
                                                display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:var(--mp-primary);">
                                        @p.Name.Substring(0,1)
                                    </div>
                                    <span style="font-weight:600;">@p.Name @p.Surname</span>
                                </div>
                            </td>
                            <td style="color:var(--mp-muted);">@p.Username</td>
                            <td>@p.Gender</td>
                            <td>
                                @if (p.MedicalAid)
                                { <span class="badge-active">@p.MedicalAidCompany</span> }
                                else
                                { <span style="color:var(--mp-muted); font-size:.875rem;">None</span> }
                            </td>
                            <td>
                                <a asp-action="PatientHistory" asp-route-id="@p.PatientId" class="btn-mp-outline" style="font-size:.8rem; padding:.35rem .9rem;">
                                    <i class="bi bi-clipboard2-pulse"></i> History
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
